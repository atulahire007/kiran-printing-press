# ================================
# KIRAN PRINTING PRESS - Backend ENV
# ================================

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/kiran_printing_press

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32chars
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (Nodemailer / Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=kiranprintingpress@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=kiranprintingpress@gmail.com
FROM_NAME=Kiran Printing Press

# SMS / OTP (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+your_twilio_phone

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Admin Default
ADMIN_EMAIL=admin@kiranprinting.com
ADMIN_PASSWORD=Admin@1234

# WhatsApp Business
WHATSAPP_NUMBER=+919876543210

# Business Info
BUSINESS_NAME=Kiran Printing Press
BUSINESS_CITY=Dharashiv
BUSINESS_STATE=Maharashtra
BUSINESS_GST=27XXXXX0000X1ZX
