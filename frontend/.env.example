# ================================
# KIRAN PRINTING PRESS - Frontend ENV
# ================================

# API Base URL (use /api/v1 in production with nginx proxy)
VITE_API_URL=/api/v1

# Razorpay Public Key (starts with rzp_test_ or rzp_live_)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Google OAuth Client ID (optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# App URL
VITE_APP_URL=https://kiranprinting.com

# Google Maps API Key (optional, for enhanced maps)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# WhatsApp Number
VITE_WHATSAPP_NUMBER=919876543210
